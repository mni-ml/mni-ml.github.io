---
import { render } from 'astro:content';
import { getAdjacentArticles, getAllArticles, getArticleNav, getArticleRailSections } from '../../lib/articles';
import LessonLayout from '../../layouts/LessonLayout.astro';

export async function getStaticPaths() {
  const articles = await getAllArticles();

  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const articles = await getAllArticles();
const articleNav = getArticleNav(articles);
const { current, prev, next } = getAdjacentArticles(articleNav, article.id);
const { Content, headings } = await render(article);
const sectionNav = getArticleRailSections(headings, article.data.presentation);
---

<LessonLayout
  title={article.data.title}
  description={article.data.description}
  pubDate={article.data.pubDate}
  updatedDate={article.data.updatedDate}
  author={article.data.author}
  tags={article.data.tags}
  ogImage={article.data.ogImage}
  slug={article.id}
  sequence={current?.sequence ?? 1}
  articleNav={articleNav}
  sectionNav={sectionNav}
  prevArticle={prev}
  nextArticle={next}
  presentation={article.data.presentation}
>
  <Content />
</LessonLayout>
