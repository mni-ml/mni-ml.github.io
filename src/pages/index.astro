---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import { getAllArticles, getArticleNav } from '../lib/articles';

const articles = await getAllArticles();
const articleNav = getArticleNav(articles);
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="mni-ml"
  description="A curriculum for understanding machine learning from scratch"
>
  <div class="mni-layout">
    <Sidebar articleNav={articleNav} railTitle="articles" />
    <main class="mni-content">
      <h1 class="home-title">mni-ml</h1>
      <p class="home-desc">
        Understanding machine learning by building it from scratch.
      </p>

      <div class="modules">
        {articleNav.map((article) => (
          <a href={`${base}/articles/${article.slug}/`} class="module-card">
            <span class="module-order">{article.sequence.toString().padStart(2, '0')}</span>
            <div>
              <div class="module-title">{article.title}</div>
              <div class="module-desc">{article.description}</div>
            </div>
          </a>
        ))}
      </div>
    </main>
  </div>
</BaseLayout>

<style>
  .mni-layout {
    display: flex;
    min-height: calc(100dvh - 44px);
  }

  .mni-content {
    flex: 1;
    padding: 36px 48px;
  }

  .home-title {
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.03em;
    margin: 0 0 6px;
  }

  .home-desc {
    font-size: 12.5px;
    color: var(--muted);
    margin: 0 0 32px;
    padding-bottom: 20px;
    border-bottom: 0.5px solid var(--bdr);
  }

  .modules {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .module-card {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 14px 16px;
    border: 0.5px solid var(--bdr);
    border-radius: 6px;
    text-decoration: none;
    color: var(--txt);
    transition: border-color 0.2s;
    margin-bottom: 8px;
  }

  .module-card:hover {
    border-color: var(--acc);
    text-decoration: none;
  }

  .module-order {
    font-size: 11px;
    color: var(--muted);
    min-width: 18px;
    padding-top: 1px;
  }

  .module-title {
    font-size: 13px;
    font-weight: 500;
  }

  .module-desc {
    font-size: 11px;
    color: var(--muted);
    margin-top: 3px;
  }

  @media (max-width: 768px) {
    .mni-content {
      padding: 24px 16px;
    }
  }
</style>
