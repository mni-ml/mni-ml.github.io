---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-content">
    <p>&copy; {year} TSTorch Notebook. Built with <a href="https://astro.build">Astro</a>.</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: 2rem 0;
    margin-top: 4rem;
  }

  .footer-content {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 1.5rem;
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  a {
    color: var(--color-text-muted);
  }
</style>
