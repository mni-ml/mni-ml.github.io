---
const base = import.meta.env.BASE_URL;
const navLinks = [
  { href: `${base}/`, label: 'home' },
  { href: 'https://github.com/mni-ml/framework', label: 'repo' },
];
---

<header class="mni-nav">
  <a href={`${base}/`} class="mni-brand">
    <img src={`${base}/mni-ml-logo.svg`} alt="mni-ml logo" width="22" height="22" />
    mni-ml
  </a>
  <nav class="mni-nav-links">
    {navLinks.map(({ href, label }) => (
      <a href={href}>{label}</a>
    ))}
  </nav>
</header>

<style>
  .mni-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 13px 24px;
    border-bottom: 0.5px solid var(--bdr);
  }

  .mni-brand {
    display: flex;
    align-items: center;
    gap: 9px;
    font-size: 14px;
    font-weight: 500;
    color: var(--txt);
    text-decoration: none;
  }

  .mni-brand:hover {
    text-decoration: none;
  }

  .mni-nav-links {
    display: flex;
    gap: 20px;
    font-size: 12px;
  }

  .mni-nav-links a {
    color: var(--muted);
    text-decoration: none;
  }

  .mni-nav-links a:hover {
    color: var(--acc);
    text-decoration: none;
  }
</style>
