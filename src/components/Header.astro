---
const navLinks = [
  { href: '/', label: 'home' },
  { href: '/rss.xml', label: 'rss' },
];
---

<header class="mni-nav">
  <a href="/" class="mni-brand">
    <svg width="22" height="17" viewBox="0 0 100 76" fill="none">
      <polygon points="0,0 18,0 58,38 18,76 0,76 40,38" fill="white" />
      <polygon points="100,0 82,0 42,38 82,76 100,76 60,38" fill="white" />
    </svg>
    mni-ml
  </a>
  <nav class="mni-nav-links">
    {navLinks.map(({ href, label }) => (
      <a href={href}>{label}</a>
    ))}
  </nav>
</header>

<style>
  .mni-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 13px 24px;
    border-bottom: 0.5px solid var(--bdr);
  }

  .mni-brand {
    display: flex;
    align-items: center;
    gap: 9px;
    font-size: 14px;
    font-weight: 500;
    color: var(--txt);
    text-decoration: none;
  }

  .mni-brand:hover {
    text-decoration: none;
  }

  .mni-nav-links {
    display: flex;
    gap: 20px;
    font-size: 12px;
  }

  .mni-nav-links a {
    color: var(--muted);
    text-decoration: none;
  }

  .mni-nav-links a:hover {
    color: var(--acc);
    text-decoration: none;
  }
</style>
