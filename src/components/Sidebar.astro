---
import { getAllArticles } from '../lib/articles';

interface Props {
  activeSlug?: string;
}

const { activeSlug } = Astro.props;
const base = import.meta.env.BASE_URL;
const articles = await getAllArticles();
---

<aside class="mni-toc">
  <div class="mni-toc-label">curriculum</div>
  {articles.map((article) => (
    <a
      href={`${base}articles/${article.id}/`}
      class:list={['mni-toc-module', { active: article.id === activeSlug }]}
    >
      {article.data.title}
    </a>
  ))}
</aside>

<style>
  .mni-toc {
    width: 192px;
    flex-shrink: 0;
    border-right: 0.5px solid var(--bdr);
    padding: 24px 0;
  }

  .mni-toc-label {
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0 20px 10px;
  }

  .mni-toc-module {
    display: block;
    font-size: 12px;
    padding: 5px 20px;
    border-left: 2px solid transparent;
    color: var(--muted);
    text-decoration: none;
    cursor: pointer;
  }

  .mni-toc-module:hover {
    color: var(--txt);
    text-decoration: none;
  }

  .mni-toc-module.active {
    color: var(--txt);
    font-weight: 500;
  }

  .mni-toc-sub {
    font-size: 11px;
    padding: 4px 20px 4px 30px;
    color: var(--muted);
    border-left: 2px solid transparent;
  }

  .mni-toc-sub.soon {
    color: var(--soon-txt);
    font-style: italic;
  }

  .mni-toc-sep {
    height: 0.5px;
    background: var(--bdr);
    margin: 12px 20px;
  }

  @media (max-width: 768px) {
    .mni-toc {
      display: none;
    }
  }
</style>
