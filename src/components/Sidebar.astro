---
import type { ArticleNavItem, ArticleRailSection } from '../lib/articles';

interface Props {
  articleNav: ArticleNavItem[];
  activeSlug?: string;
  sectionNav?: ArticleRailSection[];
  railTitle?: string;
}

const { articleNav, activeSlug, sectionNav = [], railTitle = 'curriculum' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<aside class="mni-toc">
  <div class="mni-toc-label">{railTitle}</div>
  {articleNav.map((article) => (
    <>
      <a
        href={`${base}/articles/${article.slug}/`}
        class:list={['mni-toc-module', { active: article.slug === activeSlug }]}
      >
        <span class="mni-toc-number">{article.sequence.toString().padStart(2, '0')}</span>
        <span>{article.title}</span>
      </a>
      {article.slug === activeSlug && sectionNav.length > 0 && (
        <>
          {sectionNav.filter((section) => !section.soon).map((section) => (
            <a
              href={section.slug ? `#${section.slug}` : undefined}
              class:list={['mni-toc-sub', `depth-${section.depth}`]}
            >
              {section.label}
            </a>
          ))}
          {sectionNav.some((section) => section.soon) && (
            <>
              <div class="mni-toc-sep" />
              {sectionNav.filter((section) => section.soon).map((section) => (
                <span class="mni-toc-sub soon">{section.label}</span>
              ))}
            </>
          )}
        </>
      )}
    </>
  ))}
</aside>

<style>
  .mni-toc {
    width: 192px;
    flex-shrink: 0;
    border-right: 0.5px solid var(--bdr);
    padding: 24px 0;
  }

  .mni-toc-label {
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0 20px 10px;
  }

  .mni-toc-module {
    display: flex;
    gap: 10px;
    font-size: 12px;
    padding: 5px 20px;
    border-left: 2px solid transparent;
    color: var(--muted);
    text-decoration: none;
    cursor: pointer;
  }

  .mni-toc-module:hover {
    color: var(--txt);
    text-decoration: none;
  }

  .mni-toc-module.active {
    color: var(--txt);
    font-weight: 500;
  }

  .mni-toc-number {
    color: var(--muted);
    min-width: 20px;
  }

  .mni-toc-sub {
    display: block;
    font-size: 11px;
    padding: 4px 20px 4px 30px;
    color: var(--muted);
    border-left: 2px solid transparent;
    text-decoration: none;
  }

  .mni-toc-sub.depth-3 {
    padding-left: 42px;
  }

  .mni-toc-sub.soon {
    color: var(--soon-txt);
    font-style: italic;
  }

  .mni-toc-sep {
    height: 0.5px;
    background: var(--bdr);
    margin: 12px 20px;
  }

  @media (max-width: 768px) {
    .mni-toc {
      display: none;
    }
  }
</style>
