---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import { getPrevNextArticle } from '../lib/articles';
import '../styles/article.css';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  tags: string[];
  ogImage?: string;
  slug: string;
  order: number;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  author,
  tags,
  ogImage,
  slug,
  order,
} = Astro.props;

const { prev, next } = await getPrevNextArticle(slug);
const base = import.meta.env.BASE_URL;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  author: { '@type': 'Person', name: author },
  datePublished: pubDate.toISOString(),
  ...(updatedDate && { dateModified: updatedDate.toISOString() }),
};
---

<BaseLayout
  title={title}
  description={description}
  image={ogImage}
  type="article"
  pubDate={pubDate}
  tags={tags}
>
  <div class="mni-layout">
    <Sidebar activeSlug={slug} />
    <main class="mni-content">
      <div class="lesson-eyebrow">module {order}</div>
      <h1 class="lesson-title">{title}</h1>
      <div class="lesson-meta">{description}</div>

      <div class="prose">
        <slot />
      </div>

      <nav class="lesson-pager">
        {prev ? (
          <a href={`${base}articles/${prev.id}/`} class="lesson-btn">
            &larr; {prev.data.title}
          </a>
        ) : (
          <span />
        )}
        {next ? (
          <a href={`${base}articles/${next.id}/`} class="lesson-btn">
            {next.data.title} &rarr;
          </a>
        ) : (
          <span class="lesson-btn disabled">Next &rarr;</span>
        )}
      </nav>
    </main>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <script>
    import mermaid from 'mermaid';

    mermaid.initialize({
      startOnLoad: false,
      theme: 'base',
      themeVariables: {
        darkMode: true,
        background: '#0d1117',
        fontFamily: "'IBM Plex Mono', 'SF Mono', 'Fira Code', monospace",
        fontSize: '12px',

        primaryColor: '#131923',
        primaryTextColor: '#dde4ed',
        primaryBorderColor: '#1a2535',

        secondaryColor: '#131923',
        secondaryTextColor: '#6b839e',
        secondaryBorderColor: '#1a2535',

        tertiaryColor: '#131923',
        tertiaryTextColor: '#6b839e',
        tertiaryBorderColor: '#1a2535',

        lineColor: '#38bdf8',
        textColor: '#dde4ed',

        mainBkg: '#131923',
        nodeBorder: '#1a2535',
        nodeTextColor: '#dde4ed',

        clusterBkg: 'rgba(56, 189, 248, 0.04)',
        clusterBorder: '#1a2535',
        titleColor: '#6b839e',

        edgeLabelBackground: '#0d1117',
        noteBkgColor: '#131923',
        noteTextColor: '#dde4ed',
        noteBorderColor: '#1a2535',

        actorBkg: '#131923',
        actorBorder: '#1a2535',
        actorTextColor: '#dde4ed',
        actorLineColor: '#38bdf8',
        signalColor: '#38bdf8',
        signalTextColor: '#dde4ed',
        labelBoxBkgColor: '#131923',
        labelBoxBorderColor: '#1a2535',
        labelTextColor: '#dde4ed',
        loopTextColor: '#6b839e',
        activationBkgColor: '#131923',
        activationBorderColor: '#38bdf8',
        sequenceNumberColor: '#0d1117',
      },
    });

    async function renderMermaid() {
      const blocks = document.querySelectorAll('pre[data-language="mermaid"]');
      for (const pre of blocks) {
        const code = pre.textContent ?? '';
        const container = document.createElement('div');
        container.classList.add('mermaid-diagram');
        const { svg } = await mermaid.render(
          `mermaid-${Math.random().toString(36).slice(2, 8)}`,
          code,
        );
        container.innerHTML = svg;
        pre.replaceWith(container);
      }
    }

    renderMermaid();
  </script>
</BaseLayout>

<style>
  .mni-layout {
    display: flex;
    min-height: calc(100dvh - 44px);
  }

  .mni-content {
    flex: 1;
    padding: 36px 48px;
    overflow: hidden;
    max-width: var(--content-width);
  }

  @media (max-width: 768px) {
    .mni-content {
      padding: 24px 16px;
    }
  }
</style>
