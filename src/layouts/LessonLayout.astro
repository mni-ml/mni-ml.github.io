---
import BaseLayout from './BaseLayout.astro';
import ArticleVisual from '../components/ArticleVisual.astro';
import Sidebar from '../components/Sidebar.astro';
import type { ArticleNavItem, ArticlePresentation, ArticleRailSection } from '../lib/articles';
import '../styles/article.css';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  tags: string[];
  ogImage?: string;
  slug: string;
  sequence: number;
  articleNav: ArticleNavItem[];
  sectionNav: ArticleRailSection[];
  prevArticle?: ArticleNavItem;
  nextArticle?: ArticleNavItem;
  presentation?: ArticlePresentation;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  author,
  tags,
  ogImage,
  slug,
  sequence,
  articleNav,
  sectionNav,
  prevArticle,
  nextArticle,
  presentation,
} = Astro.props;
const base = import.meta.env.BASE_URL;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  author: { '@type': 'Person', name: author },
  datePublished: pubDate.toISOString(),
  ...(updatedDate && { dateModified: updatedDate.toISOString() }),
};
---

<BaseLayout
  title={title}
  description={description}
  image={ogImage}
  type="article"
  pubDate={pubDate}
  tags={tags}
>
  <div class="mni-layout">
    <Sidebar
      activeSlug={slug}
      articleNav={articleNav}
      sectionNav={sectionNav}
      railTitle={presentation?.railTitle}
    />
    <main class="mni-content">
      <div class="lesson-eyebrow">module {sequence}</div>
      <h1 class="lesson-title">{title}</h1>
      <div class="lesson-meta">{description}</div>
      <ArticleVisual />

      <div class="prose">
        <slot />
      </div>

      <nav class="lesson-pager">
        {prevArticle ? (
          <a href={`${base}/articles/${prevArticle.slug}/`} class="lesson-btn">
            &larr; {prevArticle.title}
          </a>
        ) : (
          <span />
        )}
        {nextArticle ? (
          <a href={`${base}/articles/${nextArticle.slug}/`} class="lesson-btn">
            {nextArticle.title} &rarr;
          </a>
        ) : (
          <span class="lesson-btn disabled">Next &rarr;</span>
        )}
      </nav>
    </main>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</BaseLayout>

<style>
  .mni-layout {
    display: flex;
    min-height: calc(100dvh - 44px);
  }

  .mni-content {
    flex: 1;
    padding: 36px 48px;
    overflow: hidden;
    max-width: var(--content-width);
  }

  @media (max-width: 768px) {
    .mni-content {
      padding: 24px 16px;
    }
  }
</style>
